{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@meinc/rds-tokens": ["./packages/rds-tokens/src/index.ts"],
      "@meinc/rds-ui-core": ["./packages/rds-ui-core/src/index.ts"],
      "@meinc/rds-media-core": ["./packages/rds-media-core/src/index.ts"],
      "@meinc/rds-ai-elements": ["./packages/rds-ai-elements/src/index.ts"],
      "@meinc/rds-social-core": ["./packages/rds-social-core/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "packages/*/dist",
    "packages/*/node_modules"
  ]
}
